#!/bin/sh /etc/rc.common
# ============================================================================
#   wanmon – WAN monitor and failover service (procd)
#   (C) 2026 Pavel Bashkardin
# ============================================================================

START=99
STOP=10
USE_PROCD=1

# ----------------------------------------------------------------------------
# start_service – launch wm-daemon under procd supervision
# ----------------------------------------------------------------------------
start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/wm-daemon.sh
    procd_set_param respawn 3600 5 5   # max 5 respawns per hour, 5s delay
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

# ----------------------------------------------------------------------------
# stop_service – stop the daemon gracefully
# ----------------------------------------------------------------------------
stop_service() {
    /usr/bin/wm-daemon.sh --stop 2>/dev/null
}